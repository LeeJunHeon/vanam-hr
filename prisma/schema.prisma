generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["hr", "public"]
}

// ============================================
// public.user — SSO 사용자 검증용 (재고관리/장비관리와 공유, HR이 만들지 않음)
// ============================================
model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String? @unique
  role     String?
  isActive String  @default("Y") @map("is_active")

  @@map("user")
  @@schema("public")
}

// ============================================
// 마스터 / 룩업 테이블
// ============================================

// 통합 룩업 (status/type 라벨/색상)
model CodeLookup {
  id          Int      @id @default(autoincrement())
  category    String   @db.VarChar(50)
  code        String   @db.VarChar(50)
  label       String   @db.VarChar(100)
  color       String?  @db.VarChar(20)
  sortOrder   Int      @default(0) @map("sort_order")
  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([category, code], map: "uk_code_lookups")
  @@index([category, sortOrder], map: "idx_code_lookups_category")
  @@map("code_lookups")
  @@schema("hr")
}

// 부서 마스터
model Department {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(100)
  parentId  Int?     @map("parent_id")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  parent       Department?   @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children     Department[]  @relation("DepartmentHierarchy")
  employees    Employee[]
  approvalLine ApprovalLine?

  @@index([isActive, sortOrder], map: "idx_departments_active")
  @@map("departments")
  @@schema("hr")
}

// 직급 마스터
model Position {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  employees Employee[]

  @@index([isActive, sortOrder], map: "idx_positions_active")
  @@map("positions")
  @@schema("hr")
}

// 근태 항목 마스터
model AttendanceCategory {
  id                Int      @id @default(autoincrement())
  code              String   @unique @db.VarChar(50)
  name              String   @db.VarChar(100)
  type              String   @db.VarChar(50)
  annualLeaveDeduct Decimal? @map("annual_leave_deduct") @db.Decimal(3, 2)
  requireApproval   Boolean  @default(true) @map("require_approval")
  displayColor      String?  @map("display_color") @db.VarChar(20)
  isSystem          Boolean  @default(false) @map("is_system")
  isActive          Boolean  @default(true) @map("is_active")
  sortOrder         Int      @default(0) @map("sort_order")
  description       String?
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  attendanceDailies     AttendanceDaily[]
  attendanceRequests    AttendanceRequest[]
  calendarSources       CalendarSource[]      @relation("CalendarSourceDefaultCategory")
  calendarKeywordRules  CalendarKeywordRule[]

  @@index([isActive, sortOrder], map: "idx_attendance_categories_active")
  @@map("attendance_categories")
  @@schema("hr")
}

// 정책 키-값
model PolicySetting {
  key         String   @id @db.VarChar(100)
  value       String
  description String?
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("policy_settings")
  @@schema("hr")
}

// 시프트 패턴 라이브러리
model ShiftPattern {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  description String?
  cycleDays   Int      @map("cycle_days")
  schedule    Json
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  employeeShifts    EmployeeShift[]
  attendanceDailies AttendanceDaily[]

  @@map("shift_patterns")
  @@schema("hr")
}

// 알림 발송 시점
model NotificationSchedule {
  id           Int      @id @default(autoincrement())
  code         String   @unique @db.VarChar(50)
  name         String   @db.VarChar(100)
  triggerType  String   @map("trigger_type") @db.VarChar(50)
  dayOffset    Int      @map("day_offset")
  hourOfDay    Int      @default(9) @map("hour_of_day")
  minuteOfHour Int      @default(0) @map("minute_of_hour")
  isActive     Boolean  @default(true) @map("is_active")
  description  String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("notification_schedules")
  @@schema("hr")
}

// SNMP 폴링 주기 (시간대별)
model PollingSchedule {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)
  startTime       DateTime @map("start_time") @db.Time(6)
  endTime         DateTime @map("end_time") @db.Time(6)
  intervalSeconds Int      @map("interval_seconds")
  dayOfWeek       Int[]    @map("day_of_week")
  priority        Int      @default(0)
  isActive        Boolean  @default(true) @map("is_active")
  description     String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("polling_schedules")
  @@schema("hr")
}

// ============================================
// 핵심 엔티티
// ============================================

// 직원 마스터
model Employee {
  id           Int       @id @default(autoincrement())
  employeeNo   String?   @unique @map("employee_no") @db.VarChar(50)
  userId       Int?      @unique @map("user_id")
  name         String    @db.VarChar(100)
  email        String?   @db.VarChar(255)
  departmentId Int?      @map("department_id")
  positionId   Int?      @map("position_id")
  phone        String?   @db.VarChar(50)
  hiredAt      DateTime? @map("hired_at") @db.Date
  resignedAt   DateTime? @map("resigned_at") @db.Date
  isActive     Boolean   @default(true) @map("is_active")
  isHrOnly     Boolean   @default(false) @map("is_hr_only")
  hrSortOrder  Int?      @map("hr_sort_order")
  note         String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  department Department? @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  position   Position?   @relation(fields: [positionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  devices              Device[]
  employeeShifts       EmployeeShift[]
  presenceRaws         PresenceRaw[]
  attendanceDailies    AttendanceDaily[]
  monthlyConfirmations MonthlyConfirmation[]
  pushSubscriptions    PushSubscription[]
  notifications        Notification[]
  notificationPrefs    NotificationPref[]

  // approval_lines — 부서 결재선 (메인/대리 별도 관계)
  approvalLinesPrimary ApprovalLine[] @relation("ApprovalLinePrimary")
  approvalLinesDeputy  ApprovalLine[] @relation("ApprovalLineDeputy")

  // attendance_requests — 본인/메인결재자/대리결재자/실제승인자
  attendanceRequestsMine      AttendanceRequest[] @relation("RequestEmployee")
  attendanceRequestsAsPrimary AttendanceRequest[] @relation("RequestPrimaryApprover")
  attendanceRequestsAsDeputy  AttendanceRequest[] @relation("RequestDeputyApprover")
  attendanceRequestsApproved  AttendanceRequest[] @relation("RequestApprovedBy")

  // 그룹 출장(Field Trip) — 생성자/참가자/승인자 (같은 모델 다중 관계라 모두 이름 지정)
  tripEventsCreated   TripEvent[]       @relation("TripEventCreatedBy")
  tripParticipations  TripParticipant[] @relation("TripParticipantEmployee")
  tripApprovals       TripParticipant[] @relation("TripParticipantApprovedBy")

  // 연차 부여 기록
  annualLeaveGrants   AnnualLeaveGrant[] @relation("EmployeeAnnualLeaveGrant")

  // 개인정보 카드 (민감정보 추가 필드, 직원당 1행)
  personalInfo        EmployeePersonalInfo? @relation("EmployeePersonalInfo")

  @@index([isActive], map: "idx_employees_active")
  @@index([departmentId], map: "idx_employees_department")
  @@index([positionId], map: "idx_employees_position")
  @@index([userId], map: "idx_employees_user_id")
  @@map("employees")
  @@schema("hr")
}

// 직원 디바이스 (WiFi 출퇴근용)
model Device {
  id           Int       @id @default(autoincrement())
  employeeId   Int       @map("employee_id")
  macAddress   String    @unique @map("mac_address") @db.VarChar(32)
  hostname     String?   @db.VarChar(255)
  ipAddress    String?   @map("ip_address") @db.VarChar(45)
  deviceType   String?   @map("device_type") @db.VarChar(50)
  label        String?   @db.VarChar(100)
  isActive     Boolean   @default(true) @map("is_active")
  lastSeenAt   DateTime? @map("last_seen_at") @db.Timestamptz(6)
  registeredAt DateTime  @default(now()) @map("registered_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  employee     Employee      @relation(fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  presenceRaws PresenceRaw[]

  @@index([employeeId, isActive], map: "idx_devices_employee")
  @@map("devices")
  @@schema("hr")
}

// 직원-시프트 할당
model EmployeeShift {
  id         Int       @id @default(autoincrement())
  employeeId Int       @map("employee_id")
  patternId  Int       @map("pattern_id")
  startDate  DateTime  @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date
  override   Json?
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  employee Employee     @relation(fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  pattern  ShiftPattern @relation(fields: [patternId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([employeeId, startDate], map: "idx_employee_shifts")
  @@map("employee_shifts")
  @@schema("hr")
}

// 부서별 결재선
model ApprovalLine {
  id                Int      @id @default(autoincrement())
  departmentId      Int      @unique @map("department_id")
  primaryApproverId Int      @map("primary_approver_id")
  deputyApproverId  Int?     @map("deputy_approver_id")
  autoDelegateHours Int      @default(24) @map("auto_delegate_hours")
  approverIds       Int[]    @default([]) @map("approver_ids")
  approvalMode      String   @default("all") @map("approval_mode") @db.VarChar(10)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  department      Department @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  primaryApprover Employee   @relation("ApprovalLinePrimary", fields: [primaryApproverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  deputyApprover  Employee?  @relation("ApprovalLineDeputy", fields: [deputyApproverId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("approval_lines")
  @@schema("hr")
}

// ============================================
// 트랜잭션 / 이벤트
// ============================================

// SNMP 폴링 원시 (영구 보관, BIGSERIAL)
model PresenceRaw {
  id         BigInt   @id @default(autoincrement())
  employeeId Int?     @map("employee_id")
  deviceId   Int      @map("device_id")
  checkedAt  DateTime @map("checked_at") @db.Timestamptz(6)
  status     String   @db.VarChar(20)
  ssid       String?  @db.VarChar(100)
  rawValue   String?  @map("raw_value")
  location   String   @default("본사") @db.VarChar(10)

  employee Employee? @relation(fields: [employeeId], references: [id], onUpdate: NoAction)
  device   Device    @relation(fields: [deviceId], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([deviceId, checkedAt(sort: Desc)], map: "idx_presence_raw_dev_time")
  @@index([employeeId, checkedAt(sort: Desc)], map: "idx_presence_raw_emp_time")
  @@index([checkedAt], map: "idx_presence_raw_time")
  @@map("presence_raw")
  @@schema("hr")
}

// 일별 확정 근태
model AttendanceDaily {
  id             Int       @id @default(autoincrement())
  employeeId     Int       @map("employee_id")
  workDate       DateTime  @map("work_date") @db.Date
  checkIn        DateTime? @map("check_in") @db.Timestamptz(6)
  checkOut       DateTime? @map("check_out") @db.Timestamptz(6)
  originalCheckIn  DateTime? @map("original_check_in") @db.Timestamptz(6)
  originalCheckOut DateTime? @map("original_check_out") @db.Timestamptz(6)
  shiftPatternId Int?      @map("shift_pattern_id")
  autoStatus     String?   @map("auto_status") @db.VarChar(50)
  categoryId     Int?      @map("category_id")
  isOverridden   Boolean   @default(false) @map("is_overridden")
  overrideSource String?   @map("override_source") @db.VarChar(20)
  workMinutes    Int?      @map("work_minutes")
  note           String?
  statusReason   String?   @map("status_reason")
  isConfirmed    Boolean   @default(false) @map("is_confirmed")
  confirmedAt    DateTime? @map("confirmed_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  employee     Employee            @relation(fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  category     AttendanceCategory? @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shiftPattern ShiftPattern?       @relation(fields: [shiftPatternId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([employeeId, workDate], map: "uk_attendance_daily")
  @@index([workDate, autoStatus], map: "idx_attendance_daily_date")
  @@index([isConfirmed, workDate], map: "idx_attendance_daily_unconfirmed")
  @@map("attendance_daily")
  @@schema("hr")
}

// 변경 요청 (휴가/정정/외근 신청)
model AttendanceRequest {
  id                Int       @id @default(autoincrement())
  employeeId        Int       @map("employee_id")
  categoryId        Int       @map("category_id")
  requestType       String    @map("request_type") @db.VarChar(50)
  startDate         DateTime  @map("start_date") @db.Date
  endDate           DateTime  @map("end_date") @db.Date
  reason            String?
  externalSource    String?   @map("external_source") @db.VarChar(50)
  externalEventId   String?   @map("external_event_id") @db.VarChar(255)
  calendarSourceId         Int?      @map("calendar_source_id")
  calendarEventTitle       String?   @map("calendar_event_title")
  calendarEventDescription String?   @map("calendar_event_description")
  correctedCheckIn  DateTime? @map("corrected_check_in") @db.Timestamptz(6)
  correctedCheckOut DateTime? @map("corrected_check_out") @db.Timestamptz(6)
  status            String    @default("pending") @db.VarChar(50)
  primaryApproverId Int?      @map("primary_approver_id")
  deputyApproverId  Int?      @map("deputy_approver_id")
  approvedById      Int?      @map("approved_by_id")
  approverIds       Int[]     @default([]) @map("approver_ids")
  approvalMode      String    @default("all") @map("approval_mode") @db.VarChar(10)
  approvedByIds     Int[]     @default([]) @map("approved_by_ids")
  approvedAt        DateTime? @map("approved_at") @db.Timestamptz(6)
  rejectReason      String?   @map("reject_reason")
  requestedAt       DateTime  @default(now()) @map("requested_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  employee        Employee           @relation("RequestEmployee", fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  category        AttendanceCategory @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  calendarSource  CalendarSource?    @relation("RequestCalendarSource", fields: [calendarSourceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  primaryApprover Employee?          @relation("RequestPrimaryApprover", fields: [primaryApproverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  deputyApprover  Employee?          @relation("RequestDeputyApprover", fields: [deputyApproverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvedBy      Employee?          @relation("RequestApprovedBy", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // 그룹 출장 참가일자 역참조 — TripParticipantDate.attendanceRequestId가 이쪽으로 가리킴
  tripParticipantDates TripParticipantDate[] @relation("TripParticipantDateRequest")

  @@unique([externalSource, externalEventId], map: "uk_request_external")
  @@index([employeeId, startDate], map: "idx_requests_employee")
  @@index([primaryApproverId, status], map: "idx_requests_primary_approver")
  @@index([deputyApproverId, status], map: "idx_requests_deputy_approver")
  @@index([status, requestedAt], map: "idx_requests_status_time")
  @@map("attendance_requests")
  @@schema("hr")
}

// ============================================
// 외부 연동 / 알림
// ============================================

// ============================================
// Google Calendar 연동 (Phase 6 2단계)
// ============================================

// 동기화 대상 캘린더 목록 + 기본 카테고리
model CalendarSource {
  id                Int       @id @default(autoincrement())
  calendarId        String    @unique @map("calendar_id") @db.VarChar(255)
  calendarName      String    @map("calendar_name") @db.VarChar(100)
  defaultCategoryId Int       @map("default_category_id")
  categoryIds       Int[]     @default([]) @map("category_ids")
  syncEnabled       Boolean   @default(true) @map("sync_enabled")
  description       String?

  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  defaultCategory     AttendanceCategory   @relation("CalendarSourceDefaultCategory", fields: [defaultCategoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  keywordRules        CalendarKeywordRule[]
  attendanceRequests  AttendanceRequest[]  @relation("RequestCalendarSource")

  @@index([syncEnabled], map: "idx_calendar_sources_active")
  @@map("calendar_sources")
  @@schema("hr")
}

// 일정 제목 키워드 → 카테고리 매핑 룰
model CalendarKeywordRule {
  id                Int       @id @default(autoincrement())
  calendarSourceId  Int?      @map("calendar_source_id")
  keyword           String    @db.VarChar(100)
  categoryId        Int       @map("category_id")
  priority          Int       @default(100)
  isActive          Boolean   @default(true) @map("is_active")
  description       String?

  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  calendarSource    CalendarSource?      @relation(fields: [calendarSourceId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  category          AttendanceCategory   @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([calendarSourceId], map: "idx_keyword_rules_source")
  @@index([priority], map: "idx_keyword_rules_priority")
  @@index([isActive], map: "idx_keyword_rules_active")
  @@map("calendar_keyword_rules")
  @@schema("hr")
}

// 월별 본인 확정
model MonthlyConfirmation {
  id            Int       @id @default(autoincrement())
  employeeId    Int       @map("employee_id")
  yearMonth     String    @map("year_month") @db.VarChar(7)
  confirmedAt   DateTime? @map("confirmed_at") @db.Timestamptz(6)
  autoConfirmed Boolean   @default(false) @map("auto_confirmed")
  remindersSent Int       @default(0) @map("reminders_sent")
  note          String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@unique([employeeId, yearMonth], map: "uk_monthly_confirm")
  @@index([yearMonth, confirmedAt], map: "idx_monthly_confirm")
  @@map("monthly_confirmations")
  @@schema("hr")
}

// Web Push 구독 (PWA)
model PushSubscription {
  id         Int       @id @default(autoincrement())
  employeeId Int       @map("employee_id")
  endpoint   String    @unique
  p256dhKey  String    @map("p256dh_key")
  authKey    String    @map("auth_key")
  userAgent  String?   @map("user_agent")
  isActive   Boolean   @default(true) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([employeeId, isActive], map: "idx_push_subs_emp")
  @@map("push_subscriptions")
  @@schema("hr")
}

// 공휴일 (Google Calendar 공휴일 캘린더 → DB 캐시)
// 결근 면제 + UI 라벨 표시용. calendar-syncer가 매 사이클 갱신.
model Holiday {
  holidayDate DateTime @id @map("holiday_date") @db.Date
  name        String   @db.VarChar(200)
  source      String   @default("calendar") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("holidays")
  @@schema("hr")
}

// ============================================
// 그룹 출장 (Field Trip) — Phase 7 1단계: 모델 정의만.
// 참석자 초대/결재/캘린더 연동은 다음 단계에서 추가.
// ============================================

// 출장 이벤트 (학회/단체 출장 모임 단위)
model TripEvent {
  id               Int      @id @default(autoincrement())
  name             String   @db.VarChar(200)
  location         String?  @db.VarChar(200)
  description      String?  @db.Text
  startDate        DateTime @map("start_date") @db.Date
  endDate          DateTime @map("end_date") @db.Date
  createdById      Int      @map("created_by_id")
  creatorIsAdmin   Boolean  @default(false) @map("creator_is_admin")
  status           String   @default("active") @db.VarChar(20)
  calendarSourceId Int?     @map("calendar_source_id")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  createdBy    Employee          @relation("TripEventCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  participants TripParticipant[]

  @@index([status, startDate], map: "idx_trip_events_status_date")
  @@index([createdById], map: "idx_trip_events_creator")
  @@map("trip_events")
  @@schema("hr")
}

// 출장 참가자 (이벤트 × 직원)
model TripParticipant {
  id              Int       @id @default(autoincrement())
  tripEventId     Int       @map("trip_event_id")
  employeeId      Int       @map("employee_id")
  inviteStatus    String    @default("invited") @map("invite_status") @db.VarChar(20)
  approvalStatus  String    @default("pending") @map("approval_status") @db.VarChar(20)
  approverIds     Int[]     @default([]) @map("approver_ids")
  approvalMode    String    @default("all") @map("approval_mode")
  deputyApproverId Int?     @map("deputy_approver_id")
  approvedById    Int?      @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at") @db.Timestamptz(6)
  rejectReason    String?   @map("reject_reason")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  tripEvent  TripEvent             @relation(fields: [tripEventId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  employee   Employee              @relation("TripParticipantEmployee", fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvedBy Employee?             @relation("TripParticipantApprovedBy", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dates      TripParticipantDate[]

  @@unique([tripEventId, employeeId], map: "uk_trip_participants_event_emp")
  @@index([employeeId, approvalStatus], map: "idx_trip_participants_emp_status")
  @@map("trip_participants")
  @@schema("hr")
}

// 출장 참가자별 실제 참가일자 (이벤트 기간 중 본인이 실제 가는 날짜 N개)
// startTime/endTime: 선택 입력. 둘 다 NULL이면 종일. (DB에 이미 추가되어 있음)
model TripParticipantDate {
  id                    Int       @id @default(autoincrement())
  tripParticipantId     Int       @map("trip_participant_id")
  attendDate            DateTime  @map("attend_date") @db.Date
  startTime             DateTime? @map("start_time") @db.Time(6)
  endTime               DateTime? @map("end_time") @db.Time(6)
  calendarEventId       String?   @map("calendar_event_id") @db.VarChar(255)
  attendanceRequestId   Int?      @map("attendance_request_id")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  tripParticipant   TripParticipant    @relation(fields: [tripParticipantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  attendanceRequest AttendanceRequest? @relation("TripParticipantDateRequest", fields: [attendanceRequestId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tripParticipantId, attendDate], map: "uk_trip_participant_dates")
  @@index([attendDate], map: "idx_trip_participant_dates_date")
  @@map("trip_participant_dates")
  @@schema("hr")
}

// ============================================
// 알림 (범용 — 1차: 결재 요청)
// ============================================

// 알림 (직원별, 읽음 관리, 클릭 이동 링크)
model Notification {
  id          BigInt    @id @default(autoincrement())
  employeeId  Int       @map("employee_id")
  type        String    @db.VarChar(40)
  title       String    @db.VarChar(200)
  body        String?   @db.VarChar(500)
  linkPage    String?   @map("link_page") @db.VarChar(60)
  linkRefId   BigInt?   @map("link_ref_id")
  sourceType  String?   @map("source_type") @db.VarChar(40)
  isRead      Boolean   @default(false) @map("is_read")
  readAt      DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([employeeId, isRead, createdAt(sort: Desc)], map: "idx_notifications_emp_unread")
  @@index([employeeId, createdAt(sort: Desc)], map: "idx_notifications_emp_created")
  @@map("notifications")
  @@schema("hr")
}

// 알림 환경설정 (직원별 type on/off — 행 없으면 켜짐)
model NotificationPref {
  id          BigInt   @id @default(autoincrement())
  employeeId  Int      @map("employee_id")
  type        String   @db.VarChar(40)
  enabled     Boolean  @default(true)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([employeeId, type], map: "notification_prefs_employee_id_type_key")
  @@map("notification_prefs")
  @@schema("hr")
}

// 연차 정책 (회사 전역 1행) — 입사연차 기반 자동 부여 규칙
model AnnualLeavePolicy {
  id                   Int      @id @default(autoincrement())
  baseDays             Decimal  @default(15) @map("base_days") @db.Decimal(4, 1)
  incrementStartYear   Int      @default(3) @map("increment_start_year")
  incrementCycleYears  Int      @default(2) @map("increment_cycle_years")
  incrementDays        Decimal  @default(1) @map("increment_days") @db.Decimal(4, 1)
  maxDays              Decimal  @default(25) @map("max_days") @db.Decimal(4, 1)
  firstYearMonthly     Boolean  @default(true) @map("first_year_monthly")
  firstYearMax         Decimal  @default(11) @map("first_year_max") @db.Decimal(4, 1)
  monthlyBasis         String   @default("month") @map("monthly_basis") @db.VarChar(20)
  grantBasis           String   @default("fiscal_year") @map("grant_basis") @db.VarChar(20)
  firstYearFixedDays   Decimal  @default(0) @map("first_year_fixed_days") @db.Decimal(4, 1)
  updatedAt            DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("annual_leave_policy")
  @@schema("hr")
}

// 연차 부여 기록 (직원 × 연도)
model AnnualLeaveGrant {
  id              Int       @id @default(autoincrement())
  employeeId      Int       @map("employee_id")
  year            Int
  grantedDays     Decimal   @map("granted_days") @db.Decimal(4, 1)
  initialUsedDays Decimal   @default(0) @map("initial_used_days") @db.Decimal(4, 1)
  isManual        Boolean?  @default(false) @map("is_manual")
  note            String?
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  employee Employee @relation("EmployeeAnnualLeaveGrant", fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([employeeId, year], map: "uk_annual_leave_grant")
  @@index([year], map: "idx_annual_leave_grant_year")
  @@map("annual_leave_grant")
  @@schema("hr")
}

// 개인정보 카드 — 직원 추가(민감)정보 (직원당 1행, employee_id UNIQUE)
model EmployeePersonalInfo {
  id                  Int      @id @default(autoincrement())
  employeeId          Int      @unique @map("employee_id")
  researcherNumber    String?  @map("researcher_number") @db.VarChar(50)
  university          String?  @db.VarChar(200)
  finalDegree         String?  @map("final_degree") @db.VarChar(100)
  major               String?  @db.VarChar(200)
  graduationYearmonth String?  @map("graduation_yearmonth") @db.VarChar(20)
  degreeNumber        String?  @map("degree_number") @db.VarChar(100)
  residentNumber      String?  @map("resident_number") @db.VarChar(20)
  address             String?
  bankName            String?  @map("bank_name") @db.VarChar(100)
  accountNumber       String?  @map("account_number") @db.VarChar(50)
  accountHolder       String?  @map("account_holder") @db.VarChar(100)
  hrName              String?  @map("hr_name") @db.VarChar(100)
  hrPosition          String?  @map("hr_position") @db.VarChar(100)
  hrDepartment        String?  @map("hr_department") @db.VarChar(100)
  hrPhone             String?  @map("hr_phone") @db.VarChar(50)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  employee Employee @relation("EmployeePersonalInfo", fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("employee_personal_info")
  @@schema("hr")
}
