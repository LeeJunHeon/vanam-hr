generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["hr", "public"]
}

// ============================================
// public.user — SSO 사용자 검증용 (재고관리/장비관리와 공유, HR이 만들지 않음)
// ============================================
model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String? @unique
  role     String?
  isActive String  @default("Y") @map("is_active")

  @@map("user")
  @@schema("public")
}

// ============================================
// 마스터 / 룩업 테이블
// ============================================

// 통합 룩업 (status/type 라벨/색상)
model CodeLookup {
  id          Int      @id @default(autoincrement())
  category    String   @db.VarChar(50)
  code        String   @db.VarChar(50)
  label       String   @db.VarChar(100)
  color       String?  @db.VarChar(20)
  sortOrder   Int      @default(0) @map("sort_order")
  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([category, code], map: "uk_code_lookups")
  @@index([category, sortOrder], map: "idx_code_lookups_category")
  @@map("code_lookups")
  @@schema("hr")
}

// 부서 마스터
model Department {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(100)
  parentId  Int?     @map("parent_id")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  parent       Department?   @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children     Department[]  @relation("DepartmentHierarchy")
  employees    Employee[]
  approvalLine ApprovalLine?

  @@index([isActive, sortOrder], map: "idx_departments_active")
  @@map("departments")
  @@schema("hr")
}

// 직급 마스터
model Position {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  employees Employee[]

  @@index([isActive, sortOrder], map: "idx_positions_active")
  @@map("positions")
  @@schema("hr")
}

// 근태 항목 마스터
model AttendanceCategory {
  id                Int      @id @default(autoincrement())
  code              String   @unique @db.VarChar(50)
  name              String   @db.VarChar(100)
  type              String   @db.VarChar(50)
  annualLeaveDeduct Decimal? @map("annual_leave_deduct") @db.Decimal(3, 2)
  requireApproval   Boolean  @default(true) @map("require_approval")
  displayColor      String?  @map("display_color") @db.VarChar(20)
  isSystem          Boolean  @default(false) @map("is_system")
  isActive          Boolean  @default(true) @map("is_active")
  sortOrder         Int      @default(0) @map("sort_order")
  description       String?
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  attendanceDailies     AttendanceDaily[]
  attendanceRequests    AttendanceRequest[]
  calendarSources       CalendarSource[]      @relation("CalendarSourceDefaultCategory")
  calendarKeywordRules  CalendarKeywordRule[]

  @@index([isActive, sortOrder], map: "idx_attendance_categories_active")
  @@map("attendance_categories")
  @@schema("hr")
}

// 정책 키-값
model PolicySetting {
  key         String   @id @db.VarChar(100)
  value       String
  description String?
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("policy_settings")
  @@schema("hr")
}

// 시프트 패턴 라이브러리
model ShiftPattern {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  description String?
  cycleDays   Int      @map("cycle_days")
  schedule    Json
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  employeeShifts    EmployeeShift[]
  attendanceDailies AttendanceDaily[]

  @@map("shift_patterns")
  @@schema("hr")
}

// 알림 발송 시점
model NotificationSchedule {
  id           Int      @id @default(autoincrement())
  code         String   @unique @db.VarChar(50)
  name         String   @db.VarChar(100)
  triggerType  String   @map("trigger_type") @db.VarChar(50)
  dayOffset    Int      @map("day_offset")
  hourOfDay    Int      @default(9) @map("hour_of_day")
  minuteOfHour Int      @default(0) @map("minute_of_hour")
  isActive     Boolean  @default(true) @map("is_active")
  description  String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("notification_schedules")
  @@schema("hr")
}

// SNMP 폴링 주기 (시간대별)
model PollingSchedule {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)
  startTime       DateTime @map("start_time") @db.Time(6)
  endTime         DateTime @map("end_time") @db.Time(6)
  intervalSeconds Int      @map("interval_seconds")
  dayOfWeek       Int[]    @map("day_of_week")
  priority        Int      @default(0)
  isActive        Boolean  @default(true) @map("is_active")
  description     String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("polling_schedules")
  @@schema("hr")
}

// ============================================
// 핵심 엔티티
// ============================================

// 직원 마스터
model Employee {
  id           Int       @id @default(autoincrement())
  employeeNo   String?   @unique @map("employee_no") @db.VarChar(50)
  userId       Int?      @unique @map("user_id")
  name         String    @db.VarChar(100)
  email        String?   @db.VarChar(255)
  departmentId Int?      @map("department_id")
  positionId   Int?      @map("position_id")
  phone        String?   @db.VarChar(50)
  hiredAt      DateTime? @map("hired_at") @db.Date
  resignedAt   DateTime? @map("resigned_at") @db.Date
  isActive     Boolean   @default(true) @map("is_active")
  note         String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  department Department? @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  position   Position?   @relation(fields: [positionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  devices              Device[]
  employeeShifts       EmployeeShift[]
  presenceRaws         PresenceRaw[]
  attendanceDailies    AttendanceDaily[]
  monthlyConfirmations MonthlyConfirmation[]
  pushSubscriptions    PushSubscription[]

  // approval_lines — 부서 결재선 (메인/대리 별도 관계)
  approvalLinesPrimary ApprovalLine[] @relation("ApprovalLinePrimary")
  approvalLinesDeputy  ApprovalLine[] @relation("ApprovalLineDeputy")

  // attendance_requests — 본인/메인결재자/대리결재자/실제승인자
  attendanceRequestsMine      AttendanceRequest[] @relation("RequestEmployee")
  attendanceRequestsAsPrimary AttendanceRequest[] @relation("RequestPrimaryApprover")
  attendanceRequestsAsDeputy  AttendanceRequest[] @relation("RequestDeputyApprover")
  attendanceRequestsApproved  AttendanceRequest[] @relation("RequestApprovedBy")

  @@index([isActive], map: "idx_employees_active")
  @@index([departmentId], map: "idx_employees_department")
  @@index([positionId], map: "idx_employees_position")
  @@index([userId], map: "idx_employees_user_id")
  @@map("employees")
  @@schema("hr")
}

// 직원 디바이스 (WiFi 출퇴근용)
model Device {
  id           Int       @id @default(autoincrement())
  employeeId   Int       @map("employee_id")
  macAddress   String    @unique @map("mac_address") @db.VarChar(32)
  hostname     String?   @db.VarChar(255)
  ipAddress    String?   @map("ip_address") @db.VarChar(45)
  deviceType   String?   @map("device_type") @db.VarChar(50)
  label        String?   @db.VarChar(100)
  isActive     Boolean   @default(true) @map("is_active")
  lastSeenAt   DateTime? @map("last_seen_at") @db.Timestamptz(6)
  registeredAt DateTime  @default(now()) @map("registered_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  employee     Employee      @relation(fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  presenceRaws PresenceRaw[]

  @@index([employeeId, isActive], map: "idx_devices_employee")
  @@map("devices")
  @@schema("hr")
}

// 직원-시프트 할당
model EmployeeShift {
  id         Int       @id @default(autoincrement())
  employeeId Int       @map("employee_id")
  patternId  Int       @map("pattern_id")
  startDate  DateTime  @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date
  override   Json?
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  employee Employee     @relation(fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  pattern  ShiftPattern @relation(fields: [patternId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([employeeId, startDate], map: "idx_employee_shifts")
  @@map("employee_shifts")
  @@schema("hr")
}

// 부서별 결재선
model ApprovalLine {
  id                Int      @id @default(autoincrement())
  departmentId      Int      @unique @map("department_id")
  primaryApproverId Int      @map("primary_approver_id")
  deputyApproverId  Int?     @map("deputy_approver_id")
  autoDelegateHours Int      @default(24) @map("auto_delegate_hours")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  department      Department @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  primaryApprover Employee   @relation("ApprovalLinePrimary", fields: [primaryApproverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  deputyApprover  Employee?  @relation("ApprovalLineDeputy", fields: [deputyApproverId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("approval_lines")
  @@schema("hr")
}

// ============================================
// 트랜잭션 / 이벤트
// ============================================

// SNMP 폴링 원시 (영구 보관, BIGSERIAL)
model PresenceRaw {
  id         BigInt   @id @default(autoincrement())
  employeeId Int?     @map("employee_id")
  deviceId   Int      @map("device_id")
  checkedAt  DateTime @map("checked_at") @db.Timestamptz(6)
  status     String   @db.VarChar(20)
  ssid       String?  @db.VarChar(100)
  rawValue   String?  @map("raw_value")
  location   String   @default("본사") @db.VarChar(10)

  employee Employee? @relation(fields: [employeeId], references: [id], onUpdate: NoAction)
  device   Device    @relation(fields: [deviceId], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([deviceId, checkedAt(sort: Desc)], map: "idx_presence_raw_dev_time")
  @@index([employeeId, checkedAt(sort: Desc)], map: "idx_presence_raw_emp_time")
  @@index([checkedAt], map: "idx_presence_raw_time")
  @@map("presence_raw")
  @@schema("hr")
}

// 일별 확정 근태
model AttendanceDaily {
  id             Int       @id @default(autoincrement())
  employeeId     Int       @map("employee_id")
  workDate       DateTime  @map("work_date") @db.Date
  checkIn        DateTime? @map("check_in") @db.Timestamptz(6)
  checkOut       DateTime? @map("check_out") @db.Timestamptz(6)
  shiftPatternId Int?      @map("shift_pattern_id")
  autoStatus     String?   @map("auto_status") @db.VarChar(50)
  categoryId     Int?      @map("category_id")
  isOverridden   Boolean   @default(false) @map("is_overridden")
  workMinutes    Int?      @map("work_minutes")
  note           String?
  isConfirmed    Boolean   @default(false) @map("is_confirmed")
  confirmedAt    DateTime? @map("confirmed_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  employee     Employee            @relation(fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  category     AttendanceCategory? @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shiftPattern ShiftPattern?       @relation(fields: [shiftPatternId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([employeeId, workDate], map: "uk_attendance_daily")
  @@index([workDate, autoStatus], map: "idx_attendance_daily_date")
  @@index([isConfirmed, workDate], map: "idx_attendance_daily_unconfirmed")
  @@map("attendance_daily")
  @@schema("hr")
}

// 변경 요청 (휴가/정정/외근 신청)
model AttendanceRequest {
  id                Int       @id @default(autoincrement())
  employeeId        Int       @map("employee_id")
  categoryId        Int       @map("category_id")
  requestType       String    @map("request_type") @db.VarChar(50)
  startDate         DateTime  @map("start_date") @db.Date
  endDate           DateTime  @map("end_date") @db.Date
  reason            String?
  externalSource    String?   @map("external_source") @db.VarChar(50)
  externalEventId   String?   @map("external_event_id") @db.VarChar(255)
  correctedCheckIn  DateTime? @map("corrected_check_in") @db.Timestamptz(6)
  correctedCheckOut DateTime? @map("corrected_check_out") @db.Timestamptz(6)
  status            String    @default("pending") @db.VarChar(50)
  primaryApproverId Int?      @map("primary_approver_id")
  deputyApproverId  Int?      @map("deputy_approver_id")
  approvedById      Int?      @map("approved_by_id")
  approvedAt        DateTime? @map("approved_at") @db.Timestamptz(6)
  rejectReason      String?   @map("reject_reason")
  requestedAt       DateTime  @default(now()) @map("requested_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  employee        Employee           @relation("RequestEmployee", fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  category        AttendanceCategory @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  primaryApprover Employee?          @relation("RequestPrimaryApprover", fields: [primaryApproverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  deputyApprover  Employee?          @relation("RequestDeputyApprover", fields: [deputyApproverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvedBy      Employee?          @relation("RequestApprovedBy", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([externalSource, externalEventId], map: "uk_request_external")
  @@index([employeeId, startDate], map: "idx_requests_employee")
  @@index([primaryApproverId, status], map: "idx_requests_primary_approver")
  @@index([deputyApproverId, status], map: "idx_requests_deputy_approver")
  @@index([status, requestedAt], map: "idx_requests_status_time")
  @@map("attendance_requests")
  @@schema("hr")
}

// ============================================
// 외부 연동 / 알림
// ============================================

// ============================================
// Google Calendar 연동 (Phase 6 2단계)
// ============================================

// 동기화 대상 캘린더 목록 + 기본 카테고리
model CalendarSource {
  id                Int       @id @default(autoincrement())
  calendarId        String    @unique @map("calendar_id") @db.VarChar(255)
  calendarName      String    @map("calendar_name") @db.VarChar(100)
  defaultCategoryId Int       @map("default_category_id")
  syncEnabled       Boolean   @default(true) @map("sync_enabled")
  description       String?

  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  defaultCategory   AttendanceCategory   @relation("CalendarSourceDefaultCategory", fields: [defaultCategoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  keywordRules      CalendarKeywordRule[]

  @@index([syncEnabled], map: "idx_calendar_sources_active")
  @@map("calendar_sources")
  @@schema("hr")
}

// 일정 제목 키워드 → 카테고리 매핑 룰
model CalendarKeywordRule {
  id                Int       @id @default(autoincrement())
  calendarSourceId  Int?      @map("calendar_source_id")
  keyword           String    @db.VarChar(100)
  categoryId        Int       @map("category_id")
  priority          Int       @default(100)
  isActive          Boolean   @default(true) @map("is_active")
  description       String?

  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  calendarSource    CalendarSource?      @relation(fields: [calendarSourceId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  category          AttendanceCategory   @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([calendarSourceId], map: "idx_keyword_rules_source")
  @@index([priority], map: "idx_keyword_rules_priority")
  @@index([isActive], map: "idx_keyword_rules_active")
  @@map("calendar_keyword_rules")
  @@schema("hr")
}

// 월별 본인 확정
model MonthlyConfirmation {
  id            Int       @id @default(autoincrement())
  employeeId    Int       @map("employee_id")
  yearMonth     String    @map("year_month") @db.VarChar(7)
  confirmedAt   DateTime? @map("confirmed_at") @db.Timestamptz(6)
  autoConfirmed Boolean   @default(false) @map("auto_confirmed")
  remindersSent Int       @default(0) @map("reminders_sent")
  note          String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@unique([employeeId, yearMonth], map: "uk_monthly_confirm")
  @@index([yearMonth, confirmedAt], map: "idx_monthly_confirm")
  @@map("monthly_confirmations")
  @@schema("hr")
}

// Web Push 구독 (PWA)
model PushSubscription {
  id         Int       @id @default(autoincrement())
  employeeId Int       @map("employee_id")
  endpoint   String    @unique
  p256dhKey  String    @map("p256dh_key")
  authKey    String    @map("auth_key")
  userAgent  String?   @map("user_agent")
  isActive   Boolean   @default(true) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([employeeId, isActive], map: "idx_push_subs_emp")
  @@map("push_subscriptions")
  @@schema("hr")
}
