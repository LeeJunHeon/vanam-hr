# Next.js DB 연결 (Prisma)
DATABASE_URL=postgresql://user:password@inventory-web-postgres:5432/inventory?schema=hr

# NextAuth (Phase 7에서 실제 값 채움)
NEXTAUTH_URL=http://localhost:3998
NEXTAUTH_SECRET=your_secret_here
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 임시 인증 우회 (Phase 7 SSO 전까지)
DISABLE_AUTH=true

# === Aggregator (presence_raw → attendance_daily 변환 데몬) ===
# DB 정보는 POLLER와 동일하지만 internal network에서 호스트명/포트가 다름
# - poller: network_mode: host → POLLER_DB_HOST=localhost, POLLER_DB_PORT=5433
# - aggregator: internal + vanam-db-net → AGGREGATOR_DB_HOST=inventory-web-postgres, AGGREGATOR_DB_PORT=5432
AGGREGATOR_DB_HOST=inventory-web-postgres
AGGREGATOR_DB_PORT=5432
AGGREGATOR_DB_NAME=your_database_name
AGGREGATOR_DB_USER=your_user
AGGREGATOR_DB_PASSWORD=your_password_special_chars_ok

AGGREGATOR_INTERVAL_SECONDS=60
AGGREGATOR_LOG_LEVEL=INFO
AGGREGATOR_LOG_FILE=/app/logs/aggregator.log

# === Poller (신도림 SNMP 폴러) ===
# DB 접근: poller는 network_mode: host라 localhost:5433 사용
SNMP_COMMUNITY=
POLLER_DB_HOST=localhost
POLLER_DB_PORT=5433
POLLER_DB_NAME=
POLLER_DB_USER=
POLLER_DB_PASSWORD=
POLLER_LOG_LEVEL=INFO
POLLER_LOG_FILE=/app/logs/poller.log
POLLER_DRY_RUN=false

# ICC HTTP API (공덕 사무실)
ICC_URL=http://192.168.0.210:8800
ICC_USER=
ICC_PASSWORD=
ICC_SITE_ID=1
