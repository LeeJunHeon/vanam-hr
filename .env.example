# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://hr.vanam.synology.me

# Google OAuth (포털/재고관리/장비관리와 동일한 값 사용)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostgreSQL (재고관리 DB와 동일한 값 사용, hr 스키마)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=inventory

# 로컬 개발용 DATABASE_URL (도커 빌드 시점에는 docker-compose의 값이 우선)
DATABASE_URL=postgresql://inv_user:PASSWORD@192.168.0.210:5433/inventory?search_path=hr

# Web Push (VAPID keys — 추후 발급)
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_CONTACT=mailto:admin@vanam.co.kr

AUTH_TRUST_HOST=true

# 로컬 UI 확인용 인증 우회 (운영에서는 절대 true로 두지 말 것)
# DISABLE_AUTH=true
