# Calendar Syncer용 DB 연결 (aggregator와 동일 DB)
CALENDAR_DB_HOST=inventory-web-postgres
CALENDAR_DB_PORT=5432
CALENDAR_DB_NAME=your_database_name
CALENDAR_DB_USER=your_user
CALENDAR_DB_PASSWORD=your_password_special_chars_ok

# Google Calendar 도메인 위임
CALENDAR_SUBJECT_EMAIL=dhlee@vanam.co.kr
CALENDAR_KEY_FILE=/app/secrets/service-account-key.json

# 동기화 주기 (초) — 30분
CALENDAR_SYNC_INTERVAL=1800
# 오늘부터 며칠 뒤까지 읽을지
CALENDAR_READ_DAYS_AHEAD=7

CALENDAR_LOG_LEVEL=INFO
CALENDAR_LOG_FILE=/app/logs/calendar-syncer.log
