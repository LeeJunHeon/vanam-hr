# Aggregator용 DB 연결 (poller와 동일 DB)
AGGREGATOR_DB_HOST=inventory-web-postgres
AGGREGATOR_DB_PORT=5432
AGGREGATOR_DB_NAME=your_database_name
AGGREGATOR_DB_USER=your_user
AGGREGATOR_DB_PASSWORD=your_password_special_chars_ok

# 사이클 주기 (초)
AGGREGATOR_INTERVAL_SECONDS=60

AGGREGATOR_LOG_LEVEL=INFO
AGGREGATOR_LOG_FILE=/app/logs/aggregator.log
